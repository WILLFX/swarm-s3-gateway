# Production environment template.
# Replace every PASTE_* value with operator-controlled production secrets.
# Do not use //Alice, dev-gas-tank-seed, weak placeholder keys, or dev fallback flags in production.

S3GW_CHAIN_RPC_URL=wss://PASTE_PRODUCTION_CHAIN_RPC
S3GW_BEE_API_URL=https://PASTE_PRODUCTION_BEE_API
# Maximum buffered request body size accepted by the gateway.
# Default in code is 67108864 bytes when unset.
S3GW_MAX_REQUEST_BODY_BYTES=67108864

S3GW_BIND_ADDR=0.0.0.0:3000

S3GW_EXPECTED_REGION=us-east-1
S3GW_EXPECTED_SERVICE=s3
S3GW_ALLOW_UNSIGNED_PAYLOAD=false

S3GW_MASTER_SERVICE_KEY_HEX=PASTE_64_HEX_MASTER_SERVICE_KEY
S3GW_BEE_STAMP_BATCH_ID=PASTE_64_HEX_BEE_POSTAGE_BATCH_ID

# Generate with: openssl rand -hex 32
S3GW_BEE_FEED_SECRET_KEY_HEX=PASTE_64_HEX_BEE_FEED_SECRET_KEY

# Production operator signers.
S3GW_ANCHOR_SIGNER_SURI=PASTE_PRODUCTION_ANCHOR_SIGNER_SURI
S3GW_SUDO_SIGNER_SURI=PASTE_PRODUCTION_SUDO_SIGNER_SURI
S3GW_IDENTITY_REGISTRAR_SIGNER_SURI=PASTE_PRODUCTION_IDENTITY_REGISTRAR_SIGNER_SURI
S3GW_BUCKET_OWNER_SIGNER_SURI=PASTE_PRODUCTION_BUCKET_OWNER_SIGNER_SURI

# Never enable these in production:
# S3GW_ENABLE_DEV_DEFAULTS=true
# S3GW_BEE_ALLOW_DEV_BYTES_FALLBACK=true
