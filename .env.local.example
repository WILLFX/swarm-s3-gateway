# Local development only.
# Do not use these placeholder signers or dev fallbacks in production.

S3GW_CHAIN_RPC_URL=ws://127.0.0.1:9944
S3GW_BEE_API_URL=http://127.0.0.1:1633
# Maximum buffered request body size accepted by the gateway.
# Default in code is 67108864 bytes when unset.
S3GW_MAX_REQUEST_BODY_BYTES=67108864

S3GW_BIND_ADDR=127.0.0.1:3000

S3GW_EXPECTED_REGION=us-east-1
S3GW_EXPECTED_SERVICE=s3
S3GW_ALLOW_UNSIGNED_PAYLOAD=false

S3GW_MASTER_SERVICE_KEY_HEX=PASTE_64_HEX_MASTER_SERVICE_KEY
S3GW_BEE_STAMP_BATCH_ID=PASTE_64_HEX_BEE_POSTAGE_BATCH_ID

# Local-development placeholder only. Do not use in production.
S3GW_BEE_FEED_SECRET_KEY_HEX=1111111111111111111111111111111111111111111111111111111111111111

# Local-development signers only. Do not use in production.
S3GW_ANCHOR_SIGNER_SURI=//Alice
S3GW_SUDO_SIGNER_SURI=//Alice
S3GW_IDENTITY_REGISTRAR_SIGNER_SURI=//Alice
S3GW_BUCKET_OWNER_SIGNER_SURI=//Alice

# Local-development escape hatches only. Do not enable in production.
S3GW_ENABLE_DEV_DEFAULTS=true
S3GW_BEE_ALLOW_DEV_BYTES_FALLBACK=true
